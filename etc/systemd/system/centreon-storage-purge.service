[Unit]
Description=Centreon storage and logs purge

[Service]
Type=oneshot
User=centreon
Environment=PATH=/sbin:/bin:/usr/sbin:/usr/bin
Environment=CRONTAB_EXEC_USER=
ExecStart=/bin/sh -c 'exec /usr/share/centreon/cron/centstorage_purge --config=/etc/centreon/conf.pm >> /var/log/centreon/centreon-purge.log 2>&1'
